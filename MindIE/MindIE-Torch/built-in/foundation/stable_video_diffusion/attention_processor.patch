+            BLOCK_SIZE = 1024
+            NEG_INF =-1e10 #  -1e10 # -infinity
+            EPSILON = 1e-10 
+            O = torch.zeros_like(Q).float()
+            l = torch.zeros(Q.shape[:-1])[...,None].float()
+            m = (torch.ones(Q.shape[:-1])[...,None] * NEG_INF).float()
