+
+                for i in range(Tr):
+                    Qi = Q_BLOCKS[i]
+                    Oi = O_BLOCKS[i]
+                    li = l_BLOCKS[i]
+                    mi = m_BLOCKS[i]
+                    # Q_RANGE_BLOCKSi = Q_RANGE_BLOCKS[i]
+                    scale_factor = 1 / math.sqrt(query.size(-1)) if scale is None else scale
+
+                    # scale = 1 / np.sqrt(Q.shape[-1])
+                    Qi_scaled  = Qi * scale_factor
+
+                    S_ij = torch.einsum('... i d, ... j d -> ... i j', Qi_scaled, Kj)
+                    
+                    # print('===============>')
+
+                    # Masking
+                    # causal_mask = Q_RANGE_BLOCKSi >= K_RANGE_BLOCKSj
+                    # print('NEG_INF:',NEG_INF)
+                    # S_ij = torch.where(causal_mask > 0, S_ij, NEG_INF)
+
+                    m_block_ij, _ = torch.max(S_ij, dim=-1, keepdim=True)
