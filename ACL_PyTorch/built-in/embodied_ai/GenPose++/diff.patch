+    def patched_interpolate(*args, **kwargs):
+        mode = kwargs.get('mode', None)
+        if mode is None and len(args) >= 4:
+            mode = args[3]
+    
+        if mode == 'bicubic':
+            kwargs['mode'] = 'bilinear'
+            if len(args) >= 4:
+                args = list(args)
+                args[3] = 'bilinear'
+                args = tuple(args)
+        result = _original_interpolate(*args, **kwargs)
+        return result
+
+
