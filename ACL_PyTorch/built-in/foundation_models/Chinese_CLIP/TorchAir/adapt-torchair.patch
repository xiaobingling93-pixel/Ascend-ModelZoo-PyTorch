+    def attention_new(self, x: torch.Tensor):
+        x = torch.matmul(x.transpose(1, 0), self.attn.in_proj_weight.transpose(1, 0)) + self.attn.in_proj_bias
+        query, key, value = torch.split(x, self.attn.embed_dim, -1)
+        x = torch_npu.npu_prompt_flash_attention(
+            query,
+            key,
+            value,
+            num_heads=self.attn.num_heads,
+            input_layout='BSH',
+            scale_value=1 / math.sqrt(self.attn.head_dim),
+        )
+        x = self.attn.out_proj(x).transpose(1, 0)
+        return x
