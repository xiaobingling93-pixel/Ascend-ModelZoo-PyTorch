{
  "optimizer": {
      "type": "AdamW",
      "params": {
        "lr": "auto",
        "betas": "auto",
        "eps": "auto",
        "weight_decay": "auto"
      }
  },
  "scheduler": {
      "type": "WarmupDecayLR",
      "params": {
